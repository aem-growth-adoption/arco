# Local dev secrets/vars for `wrangler dev` (copy to .dev.vars — gitignored).
#
# Ollama (local runtime). Point at your SSH-forwarded EC2 Ollama server:
#   ssh -N -L 11434:localhost:11434 user@your-ec2-host
OLLAMA_BASE_URL=http://localhost:11434/v1
# Any model you've `ollama pull`ed on the server. Setting this makes the local
# worker default to Ollama with no admin clicks (admin Model Settings overrides).
OLLAMA_MODEL=llama3.1:8b
# Output token budget (default 16384). Reasoning models spend part of it on a
# thinking phase before emitting content — keep it generous to avoid empty pages.
OLLAMA_MAX_TOKENS=16384
# Context window sent to Ollama (default 32768). Must exceed the ~15k-token RAG
# prompt or the server silently truncates it (dropping schema rules -> empty
# pages). Ollama's own default is often just 4096.
OLLAMA_NUM_CTX=32768
# Optional — set to "false" to disable the thinking phase on reasoning models
# (much faster TTFT, fewer tokens).
# OLLAMA_THINK=false
# Optional — LLM timeout in ms for Ollama (default 300000). Reasoning models with
# a large OLLAMA_MAX_TOKENS can run minutes; raise if you still hit timeouts.
# OLLAMA_TIMEOUT_MS=300000

# Cloudflare auth for the remote Vectorize/AI bindings is taken from your
# `wrangler login` session (or CLOUDFLARE_API_TOKEN). No key needed here.

# DA_* are intentionally omitted locally: /api/generate never writes to DA, and
# leaving DA tokens unset keeps the page-caching /api/persist path from touching
# the production content store.
